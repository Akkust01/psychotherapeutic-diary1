<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ЗАГОЛОВОК -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠"
                android:textSize="32sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Психотерапевтический дневник"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- ===== ЛЕКАРСТВА ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/dialog_holo_light_frame">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💊 Мои лекарства"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/addMedicineBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="+ Добавить лекарство"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/medicineList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- ===== НАСТРОЕНИЕ И СИМПТОМЫ ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/dialog_holo_light_frame">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="😊 Дневник настроения"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤒 Симптомы (через запятую)"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/symptomsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="например: головная боль, усталость, температура"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/addMoodBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Записать"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/clearHistoryBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🗑 Очистить всё"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- ГРАФИК -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📈 График динамики настроения"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/moodChart"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="8dp" />

            <!-- История -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📜 История записей"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/moodDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="#F0F0F0"
                android:text="Сегодня: --"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Нажмите на текст выше, чтобы удалить запись"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="8dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- ===== ИМТ КАЛЬКУЛЯТОР ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@android:drawable/dialog_holo_light_frame">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚖️ Калькулятор ИМТ"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/weightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Вес (кг)"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/heightInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Рост (см)"
                android:inputType="numberDecimal" />

            <Button
                android:id="@+id/calculateBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Рассчитать ИМТ" />

            <TextView
                android:id="@+id/bmiResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:gravity="center"
                android:background="#F0F0F0"
                android:text="ИМТ: --" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>